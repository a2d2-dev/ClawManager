  "cards": [
    {
      "dot": "cyan",
      "title": "Product surface",
      "items": [
        "React console calls the Go /api/v1 backend over REST and WebSocket.",
        "User-facing domains include instances, Team workspaces, runtime pools, AI Gateway, skills, and resource bundles."
      ]
    },
    {
      "dot": "emerald",
      "title": "Runtime control",
      "items": [
        "Agent Control Plane tracks registration, heartbeat, desired state, command history, and runtime skill inventory.",
        "Kubernetes services create Deployments, Services, PVCs, runtime pools, and dedicated runtime Pods."
      ]
    },
    {
      "dot": "rose",
      "title": "Governance path",
      "items": [
        "AI Gateway is the in-cluster model governance layer: model routing, risk rules, audit traces, and cost records.",
        "Resource Management compiles channels, skills, bundles, injection snapshots, and security scan results into runtime configuration."
      ]
    }
