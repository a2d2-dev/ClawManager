  "cards": [
    {
      "dot": "emerald",
      "title": "Runtime split",
      "items": [
        "Lite stays a high-density shared runtime pool for trusted low-risk work.",
        "Isolated Gateway is a no-desktop agent runtime with stronger per-agent egress control.",
        "Pro remains the dedicated desktop runtime for GUI and browser workloads."
      ]
    },
    {
      "dot": "rose",
      "title": "Issue #1 architecture change",
      "items": [
        "ClawManager owns product policy, lifecycle, gateway access, and audit.",
        "Runtime Adapter Interface hides the backend choice behind Create / Start / Stop / Status.",
        "Isolated Gateway prefers agent-sandbox Sandbox CRDs; native Pod fallback is kept for development or migration."
      ]
    },
    {
      "dot": "cyan",
      "title": "Governed execution path",
      "items": [
        "Access Gateway keeps instances private and routes console access to the selected runtime.",
        "AI Gateway provides model routing, risk decisions, trace records, and cost accounting.",
        "Egress enforcement combines proxy, CNI, and NetworkPolicy capabilities according to runtime mode."
      ]
    }
  ]
